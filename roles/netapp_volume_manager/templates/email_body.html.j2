<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; color: #333; }
  table { border-collapse: collapse; width: 100%; margin: 20px 0; }
  th, td { border: 1px solid #ddd; padding: 8px 12px; text-align: left; }
  th { background-color: #cc0000; color: white; }
  tr:nth-child(even) { background-color: #f9f9f9; }
  .pass { color: #28a745; font-weight: bold; }
  .fail { color: #dc3545; font-weight: bold; }
  .summary { background-color: #f5f5f5; padding: 15px; border-radius: 4px; margin: 10px 0; }
  .header { color: #cc0000; }
</style>
</head>
<body>
<h2 class="header">NetApp Volume Autogrow Report</h2>

<div class="summary">
  <strong>SVM:</strong> {{ netapp_target_svm }}<br>
  <strong>Host:</strong> {{ netapp_hostname }}<br>
  <strong>Growth:</strong> {{ netapp_volume_growth_percent }}%<br>
  <strong>Autosize Mode:</strong> {{ netapp_volume_autosize_target_mode }}<br>
  <strong>Date:</strong> {{ ansible_date_time.iso8601 | default('N/A') }}<br>
  <strong>Total Volumes Processed:</strong> {{ volume_details | default([]) | length }}<br>
  <strong>Passed:</strong> {{ volume_details | default([]) | selectattr('validation_passed') | list | length }}<br>
  <strong>Failed:</strong> {{ volume_details | default([]) | rejectattr('validation_passed') | list | length }}
</div>

<table>
  <thead>
    <tr>
      <th>SVM</th>
      <th>Volume</th>
      <th>Size (GB)</th>
      <th>Max Autosize (GB)</th>
      <th>Expected Max (GB)</th>
      <th>Autosize Mode</th>
      <th>Validation</th>
    </tr>
  </thead>
  <tbody>
{% for item in volume_details | default([]) %}
    <tr>
      <td>{{ item.vserver_name }}</td>
      <td>{{ item.volume_name }}</td>
      <td>{{ item.filesystem_size }}</td>
      <td>{{ item.max_autosize }}</td>
      <td>{{ item.expected_max_gb }}</td>
      <td>{{ item.autosize_mode }}</td>
      <td class="{{ 'pass' if item.validation_passed | bool else 'fail' }}">
        {{ 'PASS' if item.validation_passed | bool else 'FAIL' }}
      </td>
    </tr>
{% endfor %}
  </tbody>
</table>

<p><em>Generated by Ansible Automation Platform</em></p>
</body>
</html>
